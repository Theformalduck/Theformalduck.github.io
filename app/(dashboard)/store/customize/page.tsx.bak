"use client";import { useState, useEffect, useCallback, useRef } from "react";import Link from "next/link";import {  ArrowLeft, Loader2, Check, ExternalLink, Palette, Layout, Megaphone, Share2, Sparkles,  ShoppingCart, Star, Plus, Download, Package, Briefcase, RefreshCw, Eye, EyeOff,  Type, Layers, Globe, Trash2, Pencil, X, Search, Wand2, Move, RotateCcw,  Shield, Zap, Tag, Code2, PanelTop,} from "lucide-react";import { Button } from "@/components/ui/button";import { MediaUpload } from "@/components/ui/media-upload";import {  STORE_THEMES, FONT_STYLES, BUTTON_STYLES, CARD_STYLES, LAYOUTS,  HERO_STYLES, NAV_STYLES, IMAGE_RATIOS, BACKGROUND_EFFECTS, FOOTER_STYLES,  HERO_SIZES, HERO_TEXT_ALIGNS, STORE_TEMPLATES,  type StoreSettings, type CustomButton, DEFAULT_SETTINGS,} from "@/lib/store-themes";import { formatCurrency } from "@/lib/utils";type ButtonPreset =  | { label: string; pageType: CustomButton["pageType"] }  | { label: string; url: string };const BUTTON_PRESETS: ButtonPreset[] = [  { label: "About Me",       pageType: "about"     },  { label: "Contact Me",     pageType: "contact"   },  { label: "FAQ",            pageType: "faq"       },  { label: "Browse All",     pageType: "products"  },  { label: "View Portfolio", pageType: "portfolio" },  { label: "Book a Call",    url: "" },  { label: "Subscribe",      url: "" },];const PAGE_TYPE_LABELS: Record<NonNullable<CustomButton["pageType"]>, string> = {  about:     "About page",  contact:   "Contact page",  faq:       "FAQ page",  portfolio: "Portfolio",  products:  "All Products",};const PRESET_COLORS = [  "#29abe2", "#6366f1", "#8b5cf6", "#ec4899", "#f43f5e",  "#f97316", "#eab308", "#22c55e", "#14b8a6", "#64748b",  "#ef4444", "#a855f7", "#06b6d4", "#10b981", "#f59e0b",];const SNAP_COLS = [10, 27, 50, 73, 90];const SNAP_ROWS = [12, 28, 50, 72, 88];const SNAP_POINTS = SNAP_ROWS.flatMap(y => SNAP_COLS.map(x => ({ x, y })));const SNAP_THRESHOLD = 7;type Section = "templates" | "theme" | "hero" | "header" | "products" | "promotions" | "social" | "content" | "seo" | "advanced";const SECTION_META: Record<Section, { label: string; icon: React.ReactNode }> = {  templates:  { label: "Templates",  icon: <Wand2 className="w-4 h-4" /> },  theme:      { label: "Theme",      icon: <Palette className="w-4 h-4" /> },  hero:       { label: "Hero",       icon: <Sparkles className="w-4 h-4" /> },  header:     { label: "Header",     icon: <PanelTop className="w-4 h-4" /> },  products:   { label: "Products",   icon: <Tag className="w-4 h-4" /> },  promotions: { label: "Promotions", icon: <Megaphone className="w-4 h-4" /> },  social:     { label: "Social",     icon: <Share2 className="w-4 h-4" /> },  content:    { label: "Content",    icon: <Type className="w-4 h-4" /> },  seo:        { label: "SEO",        icon: <Search className="w-4 h-4" /> },  advanced:   { label: "Advanced",   icon: <Code2 className="w-4 h-4" /> },};type PreviewProduct = {  id: string; name: string; description: string | null;  price: number; comparePrice: number | null; type: string; images: string[];};type PreviewUser = { name: string | null; image: string | null; bio: string | null; username: string };export default function StoreCustomizePage() {  const [settings, setSettings] = useState<StoreSettings>(DEFAULT_SETTINGS);  const [loading, setLoading]   = useState(true);  const [saving, setSaving]     = useState(false);  const [saved, setSaved]       = useState(false);  const [activeSection, setActiveSection] = useState<Section | null>(null);  const [username, setUsername]   = useState("");  const [products, setProducts]   = useState<PreviewProduct[]>([]);  const [previewUser, setPreviewUser] = useState<PreviewUser>({ name: null, image: null, bio: null, username: "" });  const [editingBtn, setEditingBtn] = useState<CustomButton | null>(null);  const [newBtn, setNewBtn] = useState<{ label: string; url: string; style: CustomButton["style"]; pageType?: CustomButton["pageType"] }>({ label: "", url: "", style: "outline" });  const [addingBtn, setAddingBtn] = useState(false);  const [showPlaceholders, setShowPlaceholders] = useState(true);  const [appliedTemplate, setAppliedTemplate] = useState<string | null>(null);  const saveTimerRef = useRef<ReturnType<typeof setTimeout> | null>(null);  useEffect(() => {    const fetchJSON = async (url: string) => {      try { const r = await fetch(url); const t = await r.text(); return t ? JSON.parse(t) : {}; } catch { return {}; }    };    const fetchArr = async (url: string) => {      try { const r = await fetch(url); const t = await r.text(); return t ? JSON.parse(t) : []; } catch { return []; }    };    Promise.all([fetchJSON("/api/store/settings"), fetchJSON("/api/user/profile"), fetchArr("/api/products")])      .then(([storeData, profileData, productsData]) => {        if (storeData && Object.keys(storeData).length > 0) {          setSettings(prev => ({            ...prev,            ...storeData,            

// Boolean fields that default to true — null/undefined from DB must not become false            stickyHeader:    storeData.stickyHeader    ?? DEFAULT_SETTINGS.stickyHeader,            showSaleBadge:   storeData.showSaleBadge   ?? DEFAULT_SETTINGS.showSaleBadge,            showQuickAdd:    storeData.showQuickAdd     ?? DEFAULT_SETTINGS.showQuickAdd,            showProductType: storeData.showProductType  ?? DEFAULT_SETTINGS.showProductType,            showTrustBar:    storeData.showTrustBar     ?? DEFAULT_SETTINGS.showTrustBar,            showRatings:     storeData.showRatings      ?? DEFAULT_SETTINGS.showRatings,          }));        }        if (profileData?.username) {          setUsername(profileData.username);          setPreviewUser({ name: profileData.name ?? null, image: profileData.image ?? null, bio: profileData.bio ?? null, username: profileData.username });        }        if (Array.isArray(productsData)) {          setProducts(productsData.filter((p: any) => p.status === "ACTIVE").map((p: any) => ({            id: p.id, name: p.name, description: p.description ?? null,            price: p.price, comparePrice: p.comparePrice ?? null, type: p.type, images: p.images ?? [],          })));        }        setLoading(false);      });  }, []);  const save = useCallback(async (data: StoreSettings) => {    setSaving(true);    try {      await fetch("/api/store/settings", { method: "PUT", headers: { "Content-Type": "application/json" }, body: JSON.stringify(data) });      setSaved(true);      setTimeout(() => setSaved(false), 2000);      

// Notify any open store tabs/windows to pick up the new settings immediately.      

// BroadcastChannel works across tabs AND separate windows of the same origin.      try { const bc = new BroadcastChannel("nexus_store_preview"); bc.postMessage("updated"); bc.close(); } catch {}      try { localStorage.setItem("nexus_settings_updated", Date.now().toString()); } catch {}    } finally { setSaving(false); }  }, []);  const update = (patch: Partial<StoreSettings>) => {    const next = { ...settings, ...patch };    setSettings(next);    if (saveTimerRef.current) clearTimeout(saveTimerRef.current);    saveTimerRef.current = setTimeout(() => save(next), 150);  };  const renderSectionPanel = (section: Section): React.ReactNode => {    switch (section) {      case "templates": return (        <div className="space-y-4">          <div>            <h3 className="text-gray-900 text-sm font-semibold">Store Templates</h3>            <p className="text-gray-400 text-xs mt-0.5">Pick a preset to instantly apply a curated look. Your name, images, and social links stay untouched.</p>          </div>          <div className="grid grid-cols-2 gap-3">            {STORE_TEMPLATES.map(tpl => {              const theme = STORE_THEMES[tpl.settings.theme ?? "default"] ?? STORE_THEMES.default;              const isApplied = appliedTemplate === tpl.id;              return (                <button key={tpl.id} onClick={() => { update(tpl.settings as Partial<StoreSettings>); setAppliedTemplate(tpl.id); }}                  className={`relative flex flex-col overflow-hidden rounded-2xl border-2 transition-all text-left hover:scale-[1.02] active:scale-[0.98] ${isApplied ? "border-[#2e9cfe] shadow-lg shadow-[#2e9cfe]/20" : "border-gray-200 hover:border-gray-300"}`}>                  <div className="w-full h-28 relative overflow-hidden flex-shrink-0" style={{ background: theme.bg }}>                    <div className="absolute top-0 left-0 right-0 h-5 flex items-center px-2 gap-1 border-b z-10"                      style={{ background: tpl.settings.navStyle === "colored" ? tpl.accent : theme.navBg, borderColor: theme.border }}>                      <div className="h-1.5 w-8 rounded-full" style={{ background: tpl.settings.navStyle === "colored" ? "rgba(255,255,255,0.8)" : theme.text, opacity: 0.8 }} />                      <div className="flex-1" />                      <div className="h-1 w-3 rounded-full" style={{ background: "rgba(128,128,128,0.5)" }} />                      <div className="h-1 w-3 rounded-full ml-1" style={{ background: "rgba(128,128,128,0.5)" }} />                    </div>                    {tpl.settings.heroStyle === "product" ? (                      <div className="absolute top-5 left-0 right-0 h-16 flex items-center px-2.5"                        style={{ background: `linear-gradient(130deg, ${tpl.accent}ee 0%, ${tpl.accent}88 45%, ${theme.bg} 100%)` }}>                        <div className="flex flex-col gap-0.5 justify-center">                          <div className="h-2.5 w-14 rounded-full bg-white/90" />                          <div className="h-1.5 w-9 rounded-full bg-white/55 mt-0.5" />                          <div className="h-2 w-10 rounded mt-1" style={{ background: "rgba(255,255,255,0.3)", border: "1px solid rgba(255,255,255,0.5)" }} />                        </div>                      </div>                    ) : (                      <div className="absolute top-5 left-0 right-0 h-14 flex flex-col justify-center items-center px-3"                        style={{ background: `linear-gradient(135deg, ${tpl.accent}cc 0%, ${tpl.accent}55 100%)` }}>                        <div className="h-2 w-16 rounded-full bg-white/80 mb-1" />                        <div className="h-1.5 w-10 rounded-full bg-white/50 mb-1.5" />                        <div className="h-2.5 w-12 rounded" style={{ background: "rgba(255,255,255,0.35)", border: "1px solid rgba(255,255,255,0.5)" }} />                      </div>                    )}                    <div className="absolute bottom-1 left-2 right-2 grid grid-cols-4 gap-0.5">                      {[0,1,2,3].map(i => <div key={i} className="aspect-square rounded-sm" style={{ background: theme.surfaceHover, border: `1px solid ${theme.border}` }} />)}                    </div>                    {isApplied && (                      <div className="absolute top-1 right-1 w-5 h-5 rounded-full bg-[#2e9cfe] flex items-center justify-center shadow-md z-20">                        <Check className="w-3 h-3 text-white" />                      </div>                    )}                  </div>                  <div className="px-3 py-2 bg-white flex-1">                    <p className="text-gray-900 text-xs font-bold">{tpl.name}</p>                    <p className="text-gray-400 text-[10px] leading-tight mt-0.5 line-clamp-1">{tpl.desc}</p>                    <div className="flex flex-wrap gap-1 mt-1.5">                      {tpl.tags.map(tag => (                        <span key={tag} className="text-[9px] font-semibold px-1.5 py-0.5 rounded-full"                          style={{ background: tpl.accent + "22", color: tpl.accent === "#ffffff" ? "#888" : tpl.accent }}>                          {tag}                        </span>                      ))}                    </div>                  </div>                </button>              );            })}          </div>          <p className="text-gray-400 text-xs text-center pt-2">After applying a template, click any section to fine-tune individual settings.</p>        </div>      );      case "theme": return (        <>          <Section title="Color Scheme">            <div className="grid grid-cols-3 gap-2">              {Object.entries(STORE_THEMES).map(([key, t]) => (                <button key={key} onClick={() => update({ theme: key })}                  className={`relative h-20 rounded-xl overflow-hidden border-2 transition-all ${settings.theme === key ? "border-[#2e9cfe] scale-105 shadow-md" : "border-gray-200 hover:border-gray-300"}`}                  style={{ background: t.bg }}>                  <div className="absolute inset-x-2 bottom-7 h-0.5 rounded-full" style={{ background: t.border }} />                  <div className="absolute inset-x-3 bottom-4 h-0.5 rounded-full w-3/4" style={{ background: t.border }} />                  <div className="absolute bottom-1.5 inset-x-2 h-1.5 rounded-md" style={{ background: `${t.border}88` }} />                  <span className="absolute top-1.5 left-2 text-[10px] font-bold" style={{ color: t.text }}>{t.name}</span>                  {settings.theme === key && <span className="absolute top-1.5 right-1.5 w-4 h-4 rounded-full bg-[#2e9cfe] flex items-center justify-center"><Check className="w-2.5 h-2.5 text-white" /></span>}                </button>              ))}            </div>          </Section>          <Section title="Accent Color">            <div className="flex flex-wrap gap-2 mb-3">              {PRESET_COLORS.map(c => (                <button key={c} onClick={() => update({ primaryColor: c })}                  className={`w-7 h-7 rounded-lg border-2 transition-all hover:scale-110 ${settings.primaryColor === c ? "border-gray-900 scale-110 shadow-md" : "border-transparent"}`}                  style={{ background: c }} />              ))}            </div>            <div className="flex items-center gap-2">              <input type="color" value={settings.primaryColor} onChange={e => update({ primaryColor: e.target.value })} className="w-10 h-10 rounded-xl cursor-pointer border border-gray-200" />              <input type="text" value={settings.primaryColor} onChange={e => update({ primaryColor: e.target.value })} className="flex-1 h-10 px-3 rounded-xl bg-gray-50 border border-gray-200 text-sm font-mono text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30" />            </div>          </Section>          <Section title="Background Effect">            <div className="grid grid-cols-2 gap-2">              {Object.entries(BACKGROUND_EFFECTS).map(([key, e]) => (                <button key={key} onClick={() => update({ backgroundEffect: key })}                  className={`flex flex-col items-center gap-2 p-3 border rounded-xl transition-all ${settings.backgroundEffect === key ? "border-[#2e9cfe] bg-blue-50" : "border-gray-200 hover:border-gray-300"}`}>                  <BgEffectPreview effectKey={key} active={settings.backgroundEffect === key} />                  <span className="text-xs text-gray-600">{e.name}</span>                </button>              ))}            </div>          </Section>          <Section title="Font Style">            <div className="space-y-2">              {Object.entries(FONT_STYLES).map(([key, f]) => (                <button key={key} onClick={() => update({ fontStyle: key })}                  className={`w-full flex items-center justify-between px-4 py-3 rounded-xl border transition-all ${settings.fontStyle === key ? "border-[#2e9cfe] bg-blue-50" : "border-gray-200 hover:border-gray-300"}`}>                  <span className="text-gray-900 text-sm font-medium">{f.name}</span>                  {settings.fontStyle === key && <Check className="w-4 h-4 text-[#2e9cfe]" />}                </button>              ))}            </div>          </Section>          <Section title="Button Style">            <div className="grid grid-cols-2 gap-2 sm:grid-cols-3">              {Object.entries(BUTTON_STYLES).map(([key, b]) => (                <button key={key} onClick={() => update({ buttonStyle: key })}                  className={`flex flex-col items-center gap-2 p-3 border rounded-xl transition-all ${settings.buttonStyle === key ? "border-[#2e9cfe] bg-blue-50" : "border-gray-200 hover:border-gray-300"}`}>                  <div className={`w-20 h-8 flex items-center justify-center text-white text-xs font-semibold ${b.radius}`} style={{ background: settings.primaryColor }}>Buy Now</div>                  <span className="text-gray-600 text-xs">{b.name}</span>                </button>              ))}            </div>          </Section>          <Section title="Card Style">            <div className="grid grid-cols-2 gap-2 sm:grid-cols-3">              {Object.entries(CARD_STYLES).map(([key, c]) => (                <button key={key} onClick={() => update({ cardStyle: key })}                  className={`flex flex-col items-center gap-2 p-3 border rounded-xl transition-all ${settings.cardStyle === key ? "border-[#2e9cfe] bg-blue-50" : "border-gray-200 hover:border-gray-300"}`}>                  <div className={`w-full h-12 bg-gray-100 ${c.radius} ${c.shadow} border border-gray-200`} />                  <span className="text-gray-600 text-xs">{c.name}</span>                </button>              ))}            </div>          </Section>        </>      );      case "hero": return (        <>          <Section title="Store Name & Tagline">            <label className="block text-xs font-medium text-gray-600 mb-1.5">Store Name</label>            <input value={settings.name ?? ""} onChange={e => update({ name: e.target.value || null })} placeholder="Your store name" className="w-full h-10 px-4 rounded-xl bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30 mb-3" />            <label className="block text-xs font-medium text-gray-600 mb-1.5">Tagline</label>            <input value={settings.tagline ?? ""} onChange={e => update({ tagline: e.target.value || null })} placeholder="A short slogan or description" className="w-full h-10 px-4 rounded-xl bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30" />          </Section>          <Section title="Logo">            <MediaUpload value={settings.logoImage ?? ""} onChange={url => update({ logoImage: url || null })} accept="image" compact allowYoutube={false} />            <p className="text-gray-400 text-xs mt-1.5">Shown in the navbar and hero section</p>          </Section>          <Section title="Banner Image">            <MediaUpload value={settings.bannerImage ?? ""} onChange={url => update({ bannerImage: url || null })} accept="image" compact allowYoutube={false} />            <p className="text-gray-400 text-xs mt-1.5">Full-width image for Cover and Split hero styles</p>          </Section>          <Section title="Hero Style">            <div className="grid grid-cols-2 gap-2">              {Object.entries(HERO_STYLES).map(([key, h]) => (                <button key={key} onClick={() => update({ heroStyle: key })}                  className={`flex flex-col items-start gap-1.5 p-3.5 border rounded-xl transition-all text-left ${settings.heroStyle === key ? "border-[#2e9cfe] bg-blue-50" : "border-gray-200 hover:border-gray-300"}`}>                  <HeroStylePreview heroKey={key} active={settings.heroStyle === key} />                  <span className="text-gray-900 text-xs font-semibold mt-1">{h.name}</span>                  <span className="text-gray-400 text-[10px] leading-tight">{h.desc}</span>                </button>              ))}            </div>          </Section>          <Section title="Hero Size">            <div className="grid grid-cols-5 gap-1.5">              {Object.entries(HERO_SIZES).map(([key, h]) => (                <button key={key} onClick={() => update({ heroSize: key })}                  className={`flex flex-col items-center gap-1.5 p-2 border rounded-xl transition-all ${(settings.heroSize ?? "large") === key ? "border-[#2e9cfe] bg-blue-50" : "border-gray-200 hover:border-gray-300"}`}>                  <div className="w-full rounded-md" style={{ height: `${h.previewH}px`, background: (settings.heroSize ?? "large") === key ? "#2e9cfe33" : "#f3f4f6", minHeight: "16px" }} />                  <span className="text-[10px] text-gray-600 font-medium leading-tight text-center">{h.name}</span>                </button>              ))}            </div>          </Section>          <Section title="Hero Text Position">            {(() => {              const current = settings.elementPositions?.heroContent;              const activeIdx = current ? SNAP_POINTS.findIndex(s => s.x === current.x && s.y === current.y) : -1;              return (                <div className="space-y-2">                  <div className="grid grid-cols-5 gap-1">                    {SNAP_POINTS.map((snap, i) => (                      <button key={i} onClick={() => update({ elementPositions: { ...(settings.elementPositions ?? {}), heroContent: { x: snap.x, y: snap.y } } })}                        className={`h-8 rounded-lg border transition-all flex items-center justify-center ${activeIdx === i ? "border-[#2e9cfe] bg-blue-50" : "border-gray-200 hover:border-[#2e9cfe]/50 hover:bg-blue-50/50"}`}>                        <div className={`w-1.5 h-1.5 rounded-full ${activeIdx === i ? "bg-[#2e9cfe]" : "bg-gray-300"}`} />                      </button>                    ))}                  </div>                  <p className="text-gray-400 text-xs">Click a cell to snap hero text to that position, or drag it in the preview.</p>                </div>              );            })()}          </Section>          <Section title="CTA Button Text">            <input value={settings.ctaText ?? ""} onChange={e => update({ ctaText: e.target.value || null })} placeholder="Shop Now" className="w-full h-10 px-4 rounded-xl bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30" />            <p className="text-gray-400 text-xs mt-1.5">Leave blank to use "Shop Now"</p>          </Section>          {settings.bannerImage && (            <Section title="Hero Overlay">              <div className="space-y-3">                <div className="flex items-center justify-between mb-1">                  <span className="text-xs text-gray-500">Banner darkness</span>                  <span className="text-xs font-bold tabular-nums" style={{ color: settings.primaryColor }}>{settings.heroOverlay ?? 50}%</span>                </div>                <input type="range" min={0} max={100} step={5} value={settings.heroOverlay ?? 50} onChange={e => update({ heroOverlay: Number(e.target.value) })} className="w-full h-2 rounded-full appearance-none cursor-pointer" style={{ accentColor: settings.primaryColor }} />                <div className="flex justify-between text-[10px] text-gray-400 font-medium"><span>Transparent</span><span>Dark</span></div>                <div className="h-12 rounded-xl overflow-hidden relative mt-1">                  <div className="absolute inset-0 bg-gradient-to-br from-sky-400 to-indigo-600" />                  <div className="absolute inset-0" style={{ background: `rgba(0,0,0,${(settings.heroOverlay ?? 50) / 100})` }} />                  <div className="absolute inset-0 flex items-center justify-center"><span className="text-white text-xs font-semibold drop-shadow">Hero Preview</span></div>                </div>              </div>            </Section>          )}          <Section title="Hero Buttons">            <p className="text-gray-400 text-xs mb-3">Add links like "About Me", "Contact Me", or any custom URL.</p>            {!addingBtn && (              <div className="flex flex-wrap gap-1.5 mb-3">                {BUTTON_PRESETS.filter(p => !(settings.customButtons ?? []).some((b: CustomButton) => b.label === p.label)).map(p => (                  <button key={p.label} type="button"                    onClick={() => {                      if ("pageType" in p) {                        update({ customButtons: [...(settings.customButtons ?? []), { id: Math.random().toString(36).slice(2), label: p.label, url: "", style: "outline" as const, pageType: p.pageType }] });                      } else { setNewBtn({ label: p.label, url: "", style: "outline" }); setAddingBtn(true); }                    }}                    className="flex items-center gap-1 px-2.5 py-1 rounded-lg border border-dashed border-gray-300 text-xs text-gray-500 hover:border-[#2e9cfe] hover:text-[#2e9cfe] transition-colors">                    <Plus className="w-3 h-3" /> {p.label}                  </button>                ))}                <button type="button" onClick={() => { setNewBtn({ label: "", url: "", style: "outline", pageType: undefined }); setAddingBtn(true); }}                  className="flex items-center gap-1 px-2.5 py-1 rounded-lg bg-[#2e9cfe] text-white text-xs font-medium hover:bg-[#1a8cf0] transition-colors">                  <Plus className="w-3 h-3" /> Custom                </button>              </div>            )}            {(addingBtn || editingBtn) && (() => {              const activePageType = editingBtn ? editingBtn.pageType : newBtn.pageType;              return (                <div className="border border-[#2e9cfe]/30 rounded-xl p-3.5 mb-3 bg-blue-50/50 space-y-2.5">                  <div className="flex items-center justify-between mb-1">                    <span className="text-xs font-semibold text-gray-700">{editingBtn ? "Edit button" : "New button"}</span>                    <button type="button" onClick={() => { setAddingBtn(false); setEditingBtn(null); }} className="text-gray-400 hover:text-gray-600"><X className="w-3.5 h-3.5" /></button>                  </div>                  <input value={editingBtn ? editingBtn.label : newBtn.label} onChange={e => editingBtn ? setEditingBtn({ ...editingBtn, label: e.target.value }) : setNewBtn(p => ({ ...p, label: e.target.value }))} placeholder="Button label" className="w-full h-9 px-3 rounded-lg bg-white border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30" />                  {activePageType ? (                    <div className="flex items-center gap-2 px-3 py-2 rounded-lg bg-emerald-50 border border-emerald-200">                      <Globe className="w-3.5 h-3.5 text-emerald-600 flex-shrink-0" />                      <span className="text-xs text-emerald-700 font-medium">Links to your {PAGE_TYPE_LABELS[activePageType]} automatically</span>                    </div>                  ) : (                    <input value={editingBtn ? editingBtn.url : newBtn.url} onChange={e => editingBtn ? setEditingBtn({ ...editingBtn, url: e.target.value }) : setNewBtn(p => ({ ...p, url: e.target.value }))} placeholder="URL, e.g. https://yoursite.com" className="w-full h-9 px-3 rounded-lg bg-white border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30" />                  )}                  <div>                    <p className="text-[10px] text-gray-500 mb-1.5 font-medium">Style</p>                    <div className="grid grid-cols-3 gap-1.5">                      {(["primary", "outline", "ghost"] as const).map(s => (                        <button key={s} type="button" onClick={() => editingBtn ? setEditingBtn({ ...editingBtn, style: s }) : setNewBtn(p => ({ ...p, style: s }))}                          className={`py-1.5 rounded-lg text-[11px] font-semibold border transition-all capitalize ${(editingBtn ? editingBtn.style : newBtn.style) === s ? "border-[#2e9cfe] bg-[#2e9cfe] text-white" : "border-gray-200 text-gray-600 hover:border-gray-300"}`}>                          {s}                        </button>                      ))}                    </div>                  </div>                  <button type="button" onClick={() => {                    if (editingBtn) { update({ customButtons: (settings.customButtons ?? []).map((b: CustomButton) => b.id === editingBtn.id ? editingBtn : b) }); setEditingBtn(null); }                    else { if (!newBtn.label.trim()) return; update({ customButtons: [...(settings.customButtons ?? []), { id: Math.random().toString(36).slice(2), ...newBtn }] }); setNewBtn({ label: "", url: "", style: "outline", pageType: undefined }); setAddingBtn(false); }                  }} className="w-full h-9 rounded-lg bg-[#2e9cfe] text-white text-sm font-semibold hover:bg-[#1a8cf0] transition-colors">                    {editingBtn ? "Save changes" : "Add button"}                  </button>                </div>              );            })()}            {(settings.customButtons ?? []).length > 0 && (              <div className="space-y-1.5">                {(settings.customButtons ?? []).map((btn: CustomButton) => (                  <div key={btn.id} className="flex items-center gap-2 px-3 py-2 rounded-xl border border-gray-200 bg-white group">                    <div className="flex-1 min-w-0">                      <p className="text-sm font-semibold text-gray-800 truncate">{btn.label}</p>                      {btn.pageType ? <p className="text-[10px] text-emerald-600 truncate font-medium">→ {PAGE_TYPE_LABELS[btn.pageType]}</p> : <p className="text-[10px] text-gray-400 truncate">{btn.url || <span className="italic">No URL set</span>}</p>}                    </div>                    <span className={`text-[10px] font-semibold px-2 py-0.5 rounded-full capitalize flex-shrink-0 ${btn.style === "primary" ? "bg-blue-100 text-blue-600" : btn.style === "outline" ? "bg-gray-100 text-gray-600" : "bg-gray-50 text-gray-400"}`}>{btn.style}</span>                    <button type="button" onClick={() => { setEditingBtn(btn); setAddingBtn(false); }} className="text-gray-300 hover:text-[#2e9cfe] flex-shrink-0 transition-colors"><Pencil className="w-3.5 h-3.5" /></button>                    <button type="button" onClick={() => update({ customButtons: (settings.customButtons ?? []).filter((b: CustomButton) => b.id !== btn.id) })} className="text-gray-300 hover:text-red-500 flex-shrink-0 transition-colors"><Trash2 className="w-3.5 h-3.5" /></button>                  </div>                ))}              </div>            )}          </Section>        </>      );      case "header": return (        <>          <Section title="Navigation">            <ToggleRow label="Sticky header" desc="Header stays visible as visitors scroll down" checked={settings.stickyHeader ?? true} onChange={v => update({ stickyHeader: v })} accent={settings.primaryColor} />          </Section>          <Section title="Navigation Style">            <div className="grid grid-cols-2 gap-2">              {Object.entries(NAV_STYLES).map(([key, n]) => (                <button key={key} onClick={() => update({ navStyle: key })}                  className={`flex flex-col items-start gap-1 p-3.5 border rounded-xl transition-all text-left ${settings.navStyle === key ? "border-[#2e9cfe] bg-blue-50" : "border-gray-200 hover:border-gray-300"}`}>                  <NavStylePreview navKey={key} accent={settings.primaryColor} active={settings.navStyle === key} />                  <span className="text-gray-900 text-xs font-semibold mt-1">{n.name}</span>                  <span className="text-gray-400 text-[10px]">{n.desc}</span>                </button>              ))}            </div>          </Section>          <Section title="Announcement Ticker">            <ToggleRow label="Enable scrolling ticker" desc="Animate your announcement as a scrolling marquee" checked={settings.tickerEnabled ?? false} onChange={v => update({ tickerEnabled: v })} accent={settings.primaryColor} />            {settings.tickerEnabled && (              <>                <div className="mt-3">                  <label className="block text-xs font-medium text-gray-600 mb-1.5">Ticker Text</label>                  <input value={settings.tickerText ?? ""} onChange={e => update({ tickerText: e.target.value || null })} placeholder="Free shipping on orders over $50 🎉 · New drops every Friday ·" className="w-full h-10 px-4 rounded-xl bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30" />                  <p className="text-gray-400 text-[10px] mt-1">Use · as separator between messages</p>                </div>                <div className="mt-3">                  <label className="block text-xs font-medium text-gray-600 mb-1.5">Scroll Speed</label>                  <div className="grid grid-cols-3 gap-2">                    {(["slow", "normal", "fast"] as const).map(s => (                      <button key={s} onClick={() => update({ tickerSpeed: s })} className={`py-2 rounded-xl border text-xs font-medium capitalize transition-all ${(settings.tickerSpeed ?? "normal") === s ? "border-[#2e9cfe] bg-blue-50 text-[#2e9cfe]" : "border-gray-200 text-gray-600 hover:border-gray-300"}`}>{s}</button>                    ))}                  </div>                </div>                <div className="mt-3">                  <label className="block text-xs font-medium text-gray-600 mb-1.5">Ticker Color</label>                  <div className="flex items-center gap-2">                    <input type="color" value={settings.announcementColor} onChange={e => update({ announcementColor: e.target.value })} className="w-10 h-10 rounded-xl cursor-pointer border border-gray-200" />                    <input type="text" value={settings.announcementColor} onChange={e => update({ announcementColor: e.target.value })} className="flex-1 h-10 px-3 rounded-xl bg-gray-50 border border-gray-200 text-sm font-mono text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30" />                  </div>                </div>              </>            )}          </Section>        </>      );      case "products": return (        <>          <Section title="Product Grid">            <div className="grid grid-cols-2 gap-2">              {Object.entries(LAYOUTS).map(([key, l]) => (                <button key={key} onClick={() => update({ layout: key })}                  className={`flex flex-col items-center gap-2 p-3 border rounded-xl transition-all ${settings.layout === key ? "border-[#2e9cfe] bg-blue-50" : "border-gray-200 hover:border-gray-300"}`}>                  <LayoutPreviewIcon layoutKey={key} active={settings.layout === key} />                  <span className="text-gray-600 text-xs font-medium">{l.name}</span>                </button>              ))}            </div>          </Section>          <Section title="Product Image Ratio">            <div className="grid grid-cols-2 gap-2">              {Object.entries(IMAGE_RATIOS).map(([key, r]) => (                <button key={key} onClick={() => update({ imageRatio: key })}                  className={`flex flex-col items-center gap-2 p-3 border rounded-xl transition-all ${settings.imageRatio === key ? "border-[#2e9cfe] bg-blue-50" : "border-gray-200 hover:border-gray-300"}`}>                  <ImageRatioPreview ratioKey={key} active={settings.imageRatio === key} />                  <span className="text-gray-600 text-xs">{r.name}</span>                </button>              ))}            </div>          </Section>          <Section title="Product Badges">            <div className="space-y-3">              <ToggleRow label='Show "Sale" badge' desc="Red sale badge on discounted products" checked={settings.showSaleBadge ?? true} onChange={v => update({ showSaleBadge: v })} accent={settings.primaryColor} />              <ToggleRow label='Show "New" badge' desc="Highlights recently added products" checked={settings.showNewBadge ?? false} onChange={v => update({ showNewBadge: v })} accent={settings.primaryColor} />            </div>            {(settings.showSaleBadge || settings.showNewBadge) && (              <div className="mt-3 flex gap-2">                {settings.showSaleBadge && <span className="text-[11px] font-semibold px-2.5 py-1 rounded-full bg-red-500 text-white">Sale</span>}                {settings.showNewBadge && <span className="text-[11px] font-semibold px-2.5 py-1 rounded-full text-white" style={{ background: settings.primaryColor }}>New</span>}              </div>            )}          </Section>          <Section title="Product Card Actions">            <div className="space-y-3">              <ToggleRow label="Quick add button" desc='Slide-up "Quick add" button on card hover' checked={settings.showQuickAdd ?? true} onChange={v => update({ showQuickAdd: v })} accent={settings.primaryColor} />              <ToggleRow label="Show product type label" desc='Display "Digital", "Physical", etc. on cards' checked={settings.showProductType ?? true} onChange={v => update({ showProductType: v })} accent={settings.primaryColor} />              <ToggleRow label="Show star ratings" desc="Display 4-star rating on product cards" checked={settings.showRatings ?? true} onChange={v => update({ showRatings: v })} accent={settings.primaryColor} />            </div>          </Section>          <Section title="Trust Bar">            <ToggleRow label="Show trust bar" desc="Feature strip below hero — Secure Checkout, Returns, etc." checked={settings.showTrustBar ?? true} onChange={v => update({ showTrustBar: v })} accent={settings.primaryColor} />            {(settings.showTrustBar ?? true) && (              <div className="mt-3 space-y-2">                <p className="text-xs text-gray-400">Customize your trust badge labels.</p>                {((settings.trustBadges ?? []).length === 0 ? ["Secure Checkout", "Instant Delivery", "30-Day Returns"] : (settings.trustBadges ?? [])).map((badge: string, i: number) => {                  const badges: string[] = (settings.trustBadges ?? []).length === 0 ? ["Secure Checkout", "Instant Delivery", "30-Day Returns"] : (settings.trustBadges ?? []);                  return (                    <div key={i} className="flex items-center gap-2">                      <Shield className="w-3.5 h-3.5 text-gray-300 flex-shrink-0" />                      <input value={badge} onChange={e => { const next = [...badges]; next[i] = e.target.value; update({ trustBadges: next }); }} className="flex-1 h-9 px-3 rounded-lg bg-gray-50 border border-gray-200 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30" />                      <button onClick={() => update({ trustBadges: badges.filter((_: string, j: number) => j !== i) })} className="text-gray-300 hover:text-red-500 transition-colors flex-shrink-0"><Trash2 className="w-4 h-4" /></button>                    </div>                  );                })}                {((settings.trustBadges ?? []).length === 0 ? ["Secure Checkout", "Instant Delivery", "30-Day Returns"] : (settings.trustBadges ?? [])).length < 6 && (                  <button onClick={() => { const badges: string[] = (settings.trustBadges ?? []).length === 0 ? ["Secure Checkout", "Instant Delivery", "30-Day Returns"] : (settings.trustBadges ?? []); update({ trustBadges: [...badges, "New Benefit"] }); }}                    className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-dashed border-gray-300 text-xs text-gray-500 hover:border-[#2e9cfe] hover:text-[#2e9cfe] transition-colors">                    <Plus className="w-3 h-3" /> Add badge                  </button>                )}              </div>            )}          </Section>          <Section title="Section Heading">            <input value={settings.sectionTitle ?? ""} onChange={e => update({ sectionTitle: e.target.value || null })} placeholder='e.g. "Browse My Collection"' className="w-full h-10 px-4 rounded-xl bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30" />            <p className="text-gray-400 text-xs mt-1.5">Appears above the product grid. Leave blank to hide.</p>          </Section>          <Section title="Display Options">            <div className="space-y-3">              <ToggleRow label="Show star ratings" desc="Display 4-star rating on product cards" checked={settings.showRatings ?? true} onChange={v => update({ showRatings: v })} accent={settings.primaryColor} />              <ToggleRow label="Show product count" desc={'e.g. "12 products available" in the hero'} checked={settings.showProductCount} onChange={v => update({ showProductCount: v })} accent={settings.primaryColor} />              <ToggleRow label="Show category filters" desc="Filter chips by product type" checked={settings.showFilters} onChange={v => update({ showFilters: v })} accent={settings.primaryColor} />            </div>          </Section>        </>      );      case "promotions": return (        <Section title="Announcement Banner">          <label className="block text-xs font-medium text-gray-600 mb-1.5">Message</label>          <input value={settings.announcementText ?? ""} onChange={e => update({ announcementText: e.target.value || null })} placeholder="e.g. Free shipping on orders over $50 🎉" className="w-full h-10 px-4 rounded-xl bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30 mb-3" />          <label className="block text-xs font-medium text-gray-600 mb-1.5">Banner Color</label>          <div className="flex items-center gap-2">            <input type="color" value={settings.announcementColor} onChange={e => update({ announcementColor: e.target.value })} className="w-10 h-10 rounded-xl cursor-pointer border border-gray-200" />            <input type="text" value={settings.announcementColor} onChange={e => update({ announcementColor: e.target.value })} className="flex-1 h-10 px-3 rounded-xl bg-gray-50 border border-gray-200 text-sm font-mono text-gray-700 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30" />          </div>          {settings.announcementText && (            <div className="mt-3 px-4 py-2.5 rounded-xl text-white text-xs font-semibold text-center" style={{ background: settings.announcementColor }}>{settings.announcementText}</div>          )}        </Section>      );      case "social": return (        <>          <Section title="Social Links">            {(["instagram", "twitter", "tiktok", "youtube", "linkedin", "website"] as const).map(platform => (              <div key={platform} className="mb-3">                <label className="block text-xs font-medium text-gray-600 mb-1 capitalize">{platform}</label>                <input value={(settings.socialLinks as Record<string, string>)[platform] ?? ""} onChange={e => update({ socialLinks: { ...settings.socialLinks, [platform]: e.target.value } })} placeholder={platform === "website" ? "https://yourwebsite.com" : `https://${platform}.com/yourhandle`} className="w-full h-10 px-4 rounded-xl bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30" />              </div>            ))}          </Section>          <Section title="Footer Style">            <div className="grid grid-cols-3 gap-2">              {Object.entries(FOOTER_STYLES).map(([key, f]) => (                <button key={key} onClick={() => update({ footerStyle: key })}                  className={`flex flex-col items-center gap-2 p-3 border rounded-xl transition-all ${settings.footerStyle === key ? "border-[#2e9cfe] bg-blue-50" : "border-gray-200 hover:border-gray-300"}`}>                  <span className="text-sm">{key === "none" ? "🚫" : key === "compact" ? "▬" : "▬▬"}</span>                  <span className="text-gray-600 text-xs">{f.name}</span>                </button>              ))}            </div>          </Section>          <Section title="Policies">            <label className="block text-xs font-medium text-gray-600 mb-1">Shipping Policy</label>            <textarea value={(settings.policies as Record<string, string>).shipping ?? ""} onChange={e => update({ policies: { ...settings.policies, shipping: e.target.value } })} placeholder="Describe your shipping terms..." rows={3} className="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30 resize-none mb-3" />            <label className="block text-xs font-medium text-gray-600 mb-1">Returns & Refunds</label>            <textarea value={(settings.policies as Record<string, string>).returns ?? ""} onChange={e => update({ policies: { ...settings.policies, returns: e.target.value } })} placeholder="Describe your returns / refund policy..." rows={3} className="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30 resize-none mb-3" />            <label className="block text-xs font-medium text-gray-600 mb-1">Privacy Policy</label>            <textarea value={(settings.policies as Record<string, string>).privacy ?? ""} onChange={e => update({ policies: { ...settings.policies, privacy: e.target.value } })} placeholder="How do you handle customer data?" rows={3} className="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30 resize-none" />          </Section>        </>      );      case "content": return (        <>          <Section title="Store Pages">            <p className="text-gray-400 text-xs mb-4">Edit the content for your About, Contact, and FAQ pages.</p>            <div className="mb-5">              <div className="flex items-center gap-2 mb-2">                <span className="text-xs font-semibold text-gray-700">About page</span>                {username && <a href={`/${username}/store/about`} target="_blank" className="text-[10px] text-[#2e9cfe] hover:underline flex items-center gap-0.5"><ExternalLink className="w-2.5 h-2.5" /> Preview</a>}              </div>              <input value={settings.storePages?.about?.title ?? ""} onChange={e => update({ storePages: { ...settings.storePages, about: { ...settings.storePages?.about, title: e.target.value || undefined } } })} placeholder='Page title (default "About")' className="w-full h-9 px-3 rounded-lg bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30 mb-2" />              <textarea value={settings.storePages?.about?.content ?? ""} onChange={e => update({ storePages: { ...settings.storePages, about: { ...settings.storePages?.about, content: e.target.value || undefined } } })} placeholder="Tell visitors about yourself…" rows={4} className="w-full px-3 py-2.5 rounded-lg bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30 resize-none" />            </div>            <div className="mb-5">              <div className="flex items-center gap-2 mb-2">                <span className="text-xs font-semibold text-gray-700">Contact page</span>                {username && <a href={`/${username}/store/contact`} target="_blank" className="text-[10px] text-[#2e9cfe] hover:underline flex items-center gap-0.5"><ExternalLink className="w-2.5 h-2.5" /> Preview</a>}              </div>              <input value={settings.storePages?.contact?.title ?? ""} onChange={e => update({ storePages: { ...settings.storePages, contact: { ...settings.storePages?.contact, title: e.target.value || undefined } } })} placeholder='Page title (default "Contact")' className="w-full h-9 px-3 rounded-lg bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30 mb-2" />              <textarea value={settings.storePages?.contact?.content ?? ""} onChange={e => update({ storePages: { ...settings.storePages, contact: { ...settings.storePages?.contact, content: e.target.value || undefined } } })} placeholder="How can people reach you?" rows={3} className="w-full px-3 py-2.5 rounded-lg bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30 resize-none" />            </div>            <div>              <div className="flex items-center gap-2 mb-2">                <span className="text-xs font-semibold text-gray-700">FAQ page</span>                {username && <a href={`/${username}/store/faq`} target="_blank" className="text-[10px] text-[#2e9cfe] hover:underline flex items-center gap-0.5"><ExternalLink className="w-2.5 h-2.5" /> Preview</a>}              </div>              <input value={settings.storePages?.faq?.title ?? ""} onChange={e => update({ storePages: { ...settings.storePages, faq: { ...settings.storePages?.faq, title: e.target.value || undefined } } })} placeholder='Page title (default "FAQ")' className="w-full h-9 px-3 rounded-lg bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30 mb-2" />              <div className="space-y-2 mb-2">                {(settings.storePages?.faq?.items ?? []).map((item, i) => {                  const items = settings.storePages?.faq?.items ?? [];                  return (                    <div key={i} className="rounded-lg border border-gray-200 overflow-hidden">                      <div className="flex items-center gap-2 px-3 py-2 bg-gray-50">                        <span className="text-[10px] font-semibold text-gray-500">Q{i + 1}</span>                        <input value={item.q} onChange={e => { const next = [...items]; next[i] = { ...next[i], q: e.target.value }; update({ storePages: { ...settings.storePages, faq: { ...settings.storePages?.faq, items: next } } }); }} placeholder="Question…" className="flex-1 text-xs text-gray-900 bg-transparent outline-none placeholder:text-gray-400" />                        <button type="button" onClick={() => { const next = items.filter((_, idx) => idx !== i); update({ storePages: { ...settings.storePages, faq: { ...settings.storePages?.faq, items: next } } }); }} className="text-gray-300 hover:text-red-500 flex-shrink-0 transition-colors"><Trash2 className="w-3 h-3" /></button>                      </div>                      <textarea value={item.a} onChange={e => { const next = [...items]; next[i] = { ...next[i], a: e.target.value }; update({ storePages: { ...settings.storePages, faq: { ...settings.storePages?.faq, items: next } } }); }} placeholder="Answer…" rows={2} className="w-full px-3 py-2 text-xs text-gray-900 bg-white placeholder:text-gray-400 outline-none resize-none border-t border-gray-200" />                    </div>                  );                })}              </div>              <button type="button" onClick={() => { const items = settings.storePages?.faq?.items ?? []; update({ storePages: { ...settings.storePages, faq: { ...settings.storePages?.faq, items: [...items, { q: "", a: "" }] } } }); }}                className="flex items-center gap-1.5 px-3 py-1.5 rounded-lg border border-dashed border-gray-300 text-xs text-gray-500 hover:border-[#2e9cfe] hover:text-[#2e9cfe] transition-colors">                <Plus className="w-3 h-3" /> Add question              </button>            </div>          </Section>          <Section title="Newsletter">            <ToggleRow label="Show newsletter signup" desc="Adds an email subscription section below products" checked={settings.showNewsletter ?? false} onChange={v => update({ showNewsletter: v })} accent={settings.primaryColor} />          </Section>        </>      );      case "seo": return (        <>          <Section title="Search Engine Optimization">            <p className="text-gray-400 text-xs mb-4">Control how your store appears in Google and other search engines.</p>            <label className="block text-xs font-medium text-gray-600 mb-1.5">Page Title</label>            <input value={settings.seoTitle ?? ""} onChange={e => update({ seoTitle: e.target.value || null })} placeholder={`${settings.name ?? "My Store"} — Creator Store`} maxLength={60} className="w-full h-10 px-4 rounded-xl bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30" />            <p className="text-gray-400 text-[10px] mt-1 mb-4">Max 60 characters · {60 - (settings.seoTitle?.length ?? 0)} remaining</p>            <label className="block text-xs font-medium text-gray-600 mb-1.5">Meta Description</label>            <textarea value={settings.seoDescription ?? ""} onChange={e => update({ seoDescription: e.target.value || null })} placeholder="Describe your store in 1–2 sentences." maxLength={160} rows={3} className="w-full px-4 py-3 rounded-xl bg-gray-50 border border-gray-200 text-sm text-gray-900 placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30 resize-none" />            <p className="text-gray-400 text-[10px] mt-1">Max 160 characters · {160 - (settings.seoDescription?.length ?? 0)} remaining</p>          </Section>          <Section title="Favicon">            <MediaUpload value={settings.favicon ?? ""} onChange={url => update({ favicon: url || null })} accept="image" compact allowYoutube={false} />            <p className="text-gray-400 text-xs mt-1.5">Browser tab icon. Square image recommended (32×32 or 64×64 px).</p>          </Section>          <Section title="Search Preview">            <p className="text-gray-400 text-xs mb-3">Approximate look in Google search results:</p>            <div className="rounded-xl border border-gray-200 p-4 bg-white space-y-0.5">              <p className="text-[#1a0dab] text-sm font-medium truncate">{settings.seoTitle || `${settings.name ?? "My Store"} — Creator Store`}</p>              <p className="text-[#006621] text-[11px] truncate">nexus.app/{username}/store</p>              <p className="text-gray-600 text-xs line-clamp-2">{settings.seoDescription || "Browse products, digital downloads, and services from this creator store."}</p>            </div>          </Section>        </>      );      case "advanced": return (        <>          <Section title="Typography Scale">            <p className="text-gray-400 text-xs mb-3">Adjusts the overall font size across your store.</p>            <div className="grid grid-cols-3 gap-2">              {(["compact", "normal", "large"] as const).map(scale => (                <button key={scale} onClick={() => update({ typographyScale: scale })}                  className={`flex flex-col items-center gap-2 py-4 border rounded-xl transition-all ${(settings.typographyScale ?? "normal") === scale ? "border-[#2e9cfe] bg-blue-50" : "border-gray-200 hover:border-gray-300"}`}>                  <span style={{ fontSize: scale === "compact" ? 13 : scale === "large" ? 22 : 17, fontWeight: 800, color: (settings.typographyScale ?? "normal") === scale ? "#2e9cfe" : "#9ca3af", lineHeight: 1 }}>Aa</span>                  <span className="text-xs text-gray-600 capitalize font-medium">{scale}</span>                </button>              ))}            </div>          </Section>          <Section title="Custom CSS">            <p className="text-gray-400 text-xs mb-2">Inject custom CSS directly into your store page.</p>            <textarea value={settings.customCss ?? ""} onChange={e => update({ customCss: e.target.value || null })} placeholder={"/* Example: tighten product grid gap */\n.products-grid { gap: 12px; }"} rows={14} spellCheck={false} className="w-full px-4 py-3 rounded-xl text-green-400 text-xs font-mono border border-gray-700 focus:outline-none focus:ring-2 focus:ring-[#2e9cfe]/30 resize-y" style={{ background: "#1a1a2e" }} />            <p className="text-gray-400 text-[10px] mt-1.5 flex items-center gap-1"><Zap className="w-3 h-3" /> Changes apply to your live store instantly on save.</p>          </Section>          <Section title="Display Options">            <div className="space-y-3">              <ToggleRow label="Show product count" desc={'e.g. "12 products available" in the hero'} checked={settings.showProductCount} onChange={v => update({ showProductCount: v })} accent={settings.primaryColor} />              <ToggleRow label="Show category filters" desc="Filter chips by product type" checked={settings.showFilters} onChange={v => update({ showFilters: v })} accent={settings.primaryColor} />              <ToggleRow label="Show newsletter signup" desc="Adds an email subscription section below products" checked={settings.showNewsletter ?? false} onChange={v => update({ showNewsletter: v })} accent={settings.primaryColor} />            </div>          </Section>        </>      );      default: return null;    }  };  if (loading) {    return (      <div className="flex items-center justify-center h-64">        <Loader2 className="w-6 h-6 animate-spin text-gray-400" />      </div>    );  }  const toolbarSections: Section[] = ["templates", "theme", "seo", "advanced"];  return (    <div className="flex flex-col h-full">      {/* Header */}      <div className="flex items-center justify-between px-6 py-4 border-b border-gray-100 bg-white flex-shrink-0">        <div className="flex items-center gap-3">          <Link href="/store">            <button className="w-9 h-9 rounded-xl bg-gray-50 border border-gray-200 flex items-center justify-center text-gray-600 hover:text-gray-900 hover:bg-gray-100 transition-all">              <ArrowLeft className="w-4 h-4" />            </button>          </Link>          <div>            <h1 className="text-xl font-bold text-gray-900">Customize Store</h1>            <p className="text-gray-400 text-xs">Click any section to edit it</p>          </div>        </div>        <div className="flex items-center gap-3">          {saving && <span className="text-gray-400 text-xs flex items-center gap-1"><Loader2 className="w-3 h-3 animate-spin" /> Saving…</span>}          {saved && !saving && <span className="text-emerald-600 text-xs flex items-center gap-1"><Check className="w-3 h-3" /> Saved</span>}          {username && (            <Link href={`/${username}/store`} target="_blank">              <Button variant="outline" size="sm" className="gap-1.5">                <ExternalLink className="w-3.5 h-3.5" /> View Store              </Button>            </Link>          )}        </div>      </div>      <div className="flex flex-1 overflow-hidden">        {/* Preview area */}        <div className="flex-1 overflow-hidden flex flex-col min-w-0">          {/* Preview chrome */}          <div className="px-4 py-2.5 border-b border-gray-200 bg-white flex items-center gap-2 flex-shrink-0 flex-wrap">            <div className="flex gap-1.5 mr-1">              <div className="w-2.5 h-2.5 rounded-full bg-red-400" />              <div className="w-2.5 h-2.5 rounded-full bg-yellow-400" />              <div className="w-2.5 h-2.5 rounded-full bg-green-400" />            </div>            <span className="text-gray-400 text-xs font-mono mr-3">{username ? `/${username}/store` : "/store"}</span>            {/* Toolbar section buttons */}            <div className="flex items-center gap-1 flex-1">              {toolbarSections.map(s => {                const meta = SECTION_META[s];                return (                  <button key={s} onClick={() => setActiveSection(activeSection === s ? null : s)}                    className={`flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-lg border transition-all ${activeSection === s ? "bg-[#2e9cfe] border-[#2e9cfe] text-white" : "bg-gray-50 border-gray-200 text-gray-500 hover:text-gray-700 hover:border-gray-300"}`}>                    {meta.icon} {meta.label}                  </button>                );              })}            </div>            <button onClick={() => setShowPlaceholders(v => !v)}              title={showPlaceholders ? "Hide placeholder slots" : "Show placeholder slots"}              className={`flex items-center gap-1.5 text-xs px-2.5 py-1 rounded-lg border transition-all ${showPlaceholders ? "bg-blue-50 border-blue-200 text-blue-600" : "bg-gray-50 border-gray-200 text-gray-400"}`}>              {showPlaceholders ? <Eye className="w-3 h-3" /> : <EyeOff className="w-3 h-3" />}              Placeholders            </button>            {saving ? <span className="text-gray-400 text-xs flex items-center gap-1"><Loader2 className="w-3 h-3 animate-spin" /> Saving…</span>              : saved ? <span className="text-emerald-500 text-xs flex items-center gap-1"><Check className="w-3 h-3" /> Saved</span>              : null}          </div>          <div className="flex-1 overflow-y-auto">            <StorePreviewLive              settings={settings}              products={products}              user={previewUser}              showPlaceholders={showPlaceholders}              activeSection={activeSection}              onSectionClick={s => setActiveSection(prev => prev === s ? null : s)}              onElementMove={(key, pos) => update({ elementPositions: { ...(settings.elementPositions ?? {}), [key]: pos } })}              onElementReset={key => { const next = { ...(settings.elementPositions ?? {}) }; delete next[key]; update({ elementPositions: next }); }}            />          </div>        </div>        {/* Right settings panel — slides in when a section is active */}        {activeSection && !toolbarSections.includes(activeSection) ? null : null}        {activeSection && (          <div className="w-[360px] border-l border-gray-100 flex flex-col overflow-hidden flex-shrink-0 bg-white">            <div className="flex items-center justify-between px-5 py-3.5 border-b border-gray-100 flex-shrink-0">              <div className="flex items-center gap-2">                <span className="text-gray-500">{SECTION_META[activeSection]?.icon}</span>                <h2 className="text-sm font-semibold text-gray-900">{SECTION_META[activeSection]?.label}</h2>              </div>              <button onClick={() => setActiveSection(null)} className="w-7 h-7 rounded-lg flex items-center justify-center text-gray-400 hover:text-gray-700 hover:bg-gray-100 transition-all">                <X className="w-4 h-4" />              </button>            </div>            <div className="flex-1 overflow-y-auto p-5 space-y-7">              {renderSectionPanel(activeSection)}            </div>          </div>        )}      </div>    </div>  );}

// ── Reusable UI ────────────────────────────────────────────────────────────────function Section({ title, children }: { title: string; children: React.ReactNode }) {  return (    <div>      <h3 className="text-gray-900 text-sm font-semibold mb-3">{title}</h3>      {children}    </div>  );}function ToggleRow({ label, desc, checked, onChange, accent }: {  label: string; desc: string; checked: boolean; onChange: (v: boolean) => void; accent: string;}) {  return (    <div className="flex items-center justify-between gap-4 py-2.5 border-b border-gray-100 last:border-0">      <div className="min-w-0">        <p className="text-sm text-gray-800 font-medium leading-snug">{label}</p>        <p className="text-xs text-gray-400 mt-0.5 leading-relaxed">{desc}</p>      </div>      <button        role="switch"        aria-checked={checked}        onClick={() => onChange(!checked)}        className="relative flex-shrink-0 w-11 h-[26px] rounded-full transition-all duration-200 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-2"        style={{          background: checked ? accent : "#d1d5db",          boxShadow: checked ? `0 0 0 3px ${accent}22` : "none",        }}      >        <span          className="absolute top-[3px] w-5 h-5 rounded-full bg-white shadow-sm transition-transform duration-200 ease-in-out"          style={{ transform: checked ? "translateX(22px)" : "translateX(3px)" }}        />      </button>    </div>  );}

// ── Preview icons ──────────────────────────────────────────────────────────────function LayoutPreviewIcon({ layoutKey, active }: { layoutKey: string; active: boolean }) {  const color = active ? "#2e9cfe" : "#d1d5db";  if (layoutKey === "list")    return <div className="flex flex-col gap-1 w-12">{[0,1,2].map(i => <div key={i} className="h-3 rounded-sm" style={{ background: color }} />)}</div>;  if (layoutKey === "masonry")    return <div className="grid grid-cols-3 gap-1 w-12">{[3,5,4,4,3,5].map((h,i) => <div key={i} style={{ height: `${h*4}px`, background: color }} className="rounded-sm" />)}</div>;  if (layoutKey === "featured")    return <div className="flex flex-col gap-1 w-12"><div className="h-6 rounded-sm" style={{ background: color }} /><div className="grid grid-cols-2 gap-1"><div className="h-3 rounded-sm" style={{ background: color }} /><div className="h-3 rounded-sm" style={{ background: color }} /></div></div>;  if (layoutKey === "compact")    return <div className="grid grid-cols-4 gap-0.5 w-12">{[0,1,2,3,4,5,6,7].map(i => <div key={i} className="h-3 rounded-sm" style={{ background: color }} />)}</div>;  if (layoutKey === "2col")    return <div className="grid grid-cols-2 gap-1 w-12">{[0,1,2,3].map(i => <div key={i} className="h-5 rounded-sm" style={{ background: color }} />)}</div>;  if (layoutKey === "3col")    return <div className="grid grid-cols-3 gap-1 w-12">{[0,1,2,3,4,5].map(i => <div key={i} className="h-4 rounded-sm" style={{ background: color }} />)}</div>;  if (layoutKey === "carousel")    return <div className="flex gap-1 w-12 overflow-hidden">{[0,1,2].map(i => <div key={i} className="flex-shrink-0 w-4 h-10 rounded-sm" style={{ background: color }} />)}</div>;  

// default grid (4col)  return <div className="grid grid-cols-4 gap-0.5 w-12">{[0,1,2,3,4,5,6,7].map(i => <div key={i} className="h-4 rounded-sm" style={{ background: color }} />)}</div>;}function HeroStylePreview({ heroKey, active }: { heroKey: string; active: boolean }) {  const c = active ? "#2e9cfe" : "#d1d5db";  if (heroKey === "product") return (    <div className="w-full h-10 rounded-lg overflow-hidden flex items-center"      style={{ background: `linear-gradient(130deg, ${c}cc 0%, ${c}66 50%, #f3f4f6 100%)` }}>      <div className="flex-1 px-2 flex flex-col gap-0.5 justify-center">        <div className="h-2 w-10 rounded-full bg-white/80" />        <div className="h-1 w-7 rounded-full bg-white/50" />        <div className="h-2 w-8 rounded mt-0.5 bg-white/40" />      </div>      <div className="w-1/3 h-full flex items-center justify-end pr-1">        <div className="w-7 h-8 rounded-lg" style={{ background: "rgba(255,255,255,0.3)", border: "1px solid rgba(255,255,255,0.4)" }} />      </div>    </div>  );  if (heroKey === "storefront") return (    <div className="w-full h-10 rounded-lg overflow-hidden flex flex-col justify-end" style={{ background: `linear-gradient(135deg, ${c}33 0%, ${c}11 100%)` }}>      <div className="px-2 pb-2 flex flex-col gap-0.5">        <div className="h-2 w-14 rounded-full" style={{ background: c }} />        <div className="h-1 w-8 rounded-full" style={{ background: `${c}88` }} />        <div className="h-2.5 w-10 rounded-md mt-0.5" style={{ background: c }} />      </div>    </div>  );  if (heroKey === "centered") return (    <div className="w-full h-10 rounded-lg bg-gray-100 flex flex-col items-center justify-center gap-1">      <div className="w-4 h-4 rounded-full" style={{ background: c }} />      <div className="h-1.5 w-10 rounded-full" style={{ background: c }} />    </div>  );  if (heroKey === "split") return (    <div className="w-full h-10 rounded-lg bg-gray-100 flex items-center gap-2 px-2">      <div className="w-6 h-6 rounded-full flex-shrink-0" style={{ background: c }} />      <div className="flex-1 space-y-1"><div className="h-1.5 rounded-full" style={{ background: c }} /><div className="h-1 rounded-full w-2/3" style={{ background: `${c}88` }} /></div>    </div>  );  if (heroKey === "cover") return (    <div className="w-full h-10 rounded-lg flex flex-col items-center justify-end pb-1" style={{ background: `linear-gradient(180deg, ${c}55 0%, ${c} 100%)` }}>      <div className="h-1.5 w-12 rounded-full bg-white/80" />    </div>  );  

// minimal  return (    <div className="w-full h-10 rounded-lg bg-gray-100 flex items-center px-2 gap-2">      <div className="w-5 h-5 rounded-md flex-shrink-0" style={{ background: c }} />      <div className="h-1.5 rounded-full flex-1" style={{ background: c }} />    </div>  );}function NavStylePreview({ navKey, accent, active }: { navKey: string; accent: string; active: boolean }) {  const c = active ? "#2e9cfe" : "#d1d5db";  if (navKey === "colored") return (    <div className="w-full h-6 rounded-md flex items-center px-2 gap-1" style={{ background: accent }}>      <div className="w-3 h-1.5 rounded-full bg-white/80" /><div className="flex-1" /><div className="w-3 h-1.5 rounded-full bg-white/60" />    </div>  );  if (navKey === "transparent") return (    <div className="w-full h-6 rounded-md flex items-center px-2 gap-1 border border-dashed" style={{ borderColor: c }}>      <div className="w-3 h-1.5 rounded-full" style={{ background: `${c}88` }} /><div className="flex-1" /><div className="w-3 h-1.5 rounded-full" style={{ background: `${c}88` }} />    </div>  );  if (navKey === "minimal") return (    <div className="w-full h-6 rounded-md flex items-center px-2 gap-1">      <div className="w-3 h-1.5 rounded-full" style={{ background: c }} /><div className="flex-1" /><div className="w-3 h-1.5 rounded-full" style={{ background: c }} />    </div>  );  return (    <div className="w-full h-6 rounded-md flex items-center px-2 gap-1 border" style={{ background: "#f9fafb", borderColor: c }}>      <div className="w-3 h-1.5 rounded-full" style={{ background: c }} /><div className="flex-1" /><div className="w-3 h-1.5 rounded-full" style={{ background: c }} />    </div>  );}function ImageRatioPreview({ ratioKey, active }: { ratioKey: string; active: boolean }) {  const c = active ? "#2e9cfe" : "#d1d5db";  const dims: Record<string, string> = { square: "w-12 h-12", portrait: "w-9 h-12", landscape: "w-12 h-9", wide: "w-12 h-7" };  return <div className={`${dims[ratioKey] ?? "w-12 h-12"} rounded-md`} style={{ background: c }} />;}function BgEffectPreview({ effectKey, active }: { effectKey: string; active: boolean }) {  const c = active ? "#2e9cfe22" : "#f3f4f6";  const b = active ? "#2e9cfe" : "#d1d5db";  const styles: Record<string, React.CSSProperties> = {    none:     { background: c, border: `1px solid ${b}` },    dots:     { backgroundImage: `radial-gradient(${b} 1px, transparent 1px)`, backgroundSize: "6px 6px", background: c },    lines:    { backgroundImage: `linear-gradient(${b} 1px, transparent 1px), linear-gradient(90deg, ${b} 1px, transparent 1px)`, backgroundSize: "8px 8px", background: c },    gradient: { background: `radial-gradient(ellipse at 50% 0%, ${active ? "#2e9cfe44" : "#e5e7eb"} 0%, ${c} 70%)` },  };  return <div className="w-full h-8 rounded-lg" style={styles[effectKey] ?? styles.none} />;}

// Hero heights (px) at 960-wide desktop viewport — used by the zoom-scaled previewconst HERO_H_PX: Record<string, number> = {  fullscreen: 720, large: 540, medium: 400, small: 260, banner: 200,};

// ── Live store preview ─────────────────────────────────────────────────────────const TYPE_META: Record<string, { label: string; icon: React.ComponentType<{ className?: string; style?: React.CSSProperties }> }> = {  DIGITAL:      { label: "Digital",      icon: Download  },  PHYSICAL:     { label: "Physical",     icon: Package   },  SERVICE:      { label: "Service",      icon: Briefcase },  SUBSCRIPTION: { label: "Subscription", icon: RefreshCw },};const FALLBACK_PRODUCTS: PreviewProduct[] = [  { id: "1", name: "UI Design System",    description: "Complete component library", price: 49,  comparePrice: 79,   type: "DIGITAL",      images: [] },  { id: "2", name: "Art Print Poster",    description: "High-quality art print",     price: 25,  comparePrice: null, type: "PHYSICAL",     images: [] },  { id: "3", name: "1:1 Strategy Call",   description: "60-minute coaching call",    price: 120, comparePrice: null, type: "SERVICE",      images: [] },  { id: "4", name: "Monthly Templates",   description: "New templates every month",  price: 12,  comparePrice: null, type: "SUBSCRIPTION", images: [] },];

// How many slots to show per layout (2 rows worth so the grid shape is visible)const LAYOUT_SLOTS: Record<string, number> = {  grid: 8, "3col": 6, "2col": 4, compact: 10,  list: 5, masonry: 6, featured: 4, carousel: 5,};type DisplayItem = PreviewProduct & { _ph?: boolean };function StorePreviewLive({ settings, products, user, showPlaceholders, onElementMove, onElementReset }: {  settings: StoreSettings; products: PreviewProduct[]; user: PreviewUser; showPlaceholders: boolean;  onElementMove?: (key: string, pos: { x: number; y: number }) => void;  onElementReset?: (key: string) => void;}) {  const heroContainerRef = useRef<HTMLElement>(null);  const navContainerRef  = useRef<HTMLDivElement>(null);  const [dragging, setDragging] = useState<{    key: string; startPx: number; startPy: number; startX: number; startY: number; containerW: number; containerH: number;  } | null>(null);  const [livePositions, setLivePositions] = useState<Record<string, { x: number; y: number }>>(    settings.elementPositions ?? {}  );  

// Keep livePositions in sync when settings change externally (but not while dragging)  const isDraggingRef = useRef(false);  useEffect(() => {    if (!isDraggingRef.current) setLivePositions(settings.elementPositions ?? {});  }, [settings.elementPositions]);  const startDrag = useCallback((    e: React.PointerEvent,    key: string,    containerRef: React.RefObject<HTMLElement | HTMLDivElement | null>,  ) => {    e.preventDefault();    e.stopPropagation();    const container = containerRef.current as HTMLElement | null;    if (!container) return;    const rect = container.getBoundingClientRect();    const existing = livePositions[key];    const defaultPos = key === "heroContent"      ? (settings.heroStyle === "product" ? { x: 20, y: 50 } : { x: 50, y: 75 })      : { x: 8, y: 50 };    const startX = existing?.x ?? defaultPos.x;    const startY = existing?.y ?? defaultPos.y;    setDragging({ key, startPx: e.clientX, startPy: e.clientY, startX, startY, containerW: rect.width, containerH: rect.height });    isDraggingRef.current = true;    (e.currentTarget as HTMLElement).setPointerCapture(e.pointerId);  }, [livePositions, settings.heroStyle]);  const onPointerMove = useCallback((e: React.PointerEvent, key: string) => {    if (!dragging || dragging.key !== key) return;    const dx = e.clientX - dragging.startPx;    const dy = e.clientY - dragging.startPy;    let newX = Math.max(2, Math.min(98, dragging.startX + (dx / dragging.containerW) * 100));    let newY = key === "navLogo"      ? 50      : Math.max(2, Math.min(98, dragging.startY + (dy / dragging.containerH) * 100));    if (key === "heroContent") {      for (const snap of SNAP_POINTS) {        if (Math.abs(newX - snap.x) < SNAP_THRESHOLD && Math.abs(newY - snap.y) < SNAP_THRESHOLD) {          newX = snap.x; newY = snap.y; break;        }      }    }    setLivePositions(prev => ({ ...prev, [key]: { x: newX, y: newY } }));  }, [dragging]);  const onPointerUp = useCallback((key: string) => {    if (!dragging || dragging.key !== key) return;    const pos = livePositions[key];    setDragging(null);    isDraggingRef.current = false;    if (pos) onElementMove?.(key, pos);  }, [dragging, livePositions, onElementMove]);  const theme          = STORE_THEMES[settings.theme]        ?? STORE_THEMES.default;  const btnStyle       = BUTTON_STYLES[settings.buttonStyle] ?? BUTTON_STYLES.rounded;  const cardStyle      = CARD_STYLES[settings.cardStyle]     ?? CARD_STYLES.shadow;  const layout         = LAYOUTS[settings.layout]            ?? LAYOUTS.grid;  const imgRatio       = IMAGE_RATIOS[settings.imageRatio]   ?? IMAGE_RATIOS.square;  const accent         = settings.primaryColor;  const heroStyle      = (settings.heroStyle === "storefront" || !settings.heroStyle || settings.heroStyle === "centered") ? "storefront" : settings.heroStyle;  const navStyle       = settings.navStyle  ?? "default";  const isList         = settings.layout === "list";  const navBg =    navStyle === "colored"     ? accent :    navStyle === "transparent" ? "transparent" :    navStyle === "minimal"     ? "transparent" :    theme.navBg;  const navBorderColor  = navStyle === "transparent" || navStyle === "minimal" ? "transparent" : theme.border;  const navTextColor    = navStyle === "colored" ? "#ffffff" : theme.text;  const navMutedColor   = navStyle === "colored" ? "rgba(255,255,255,0.75)" : theme.muted;  const ctaLabel       = settings.ctaText ?? "Shop Now";  const heroOverlay    = settings.heroOverlay ?? 50;  const showNewsletter = settings.showNewsletter ?? false;  const customButtons  = (settings.customButtons ?? []) as CustomButton[];  const maxSlots    = LAYOUT_SLOTS[settings.layout] ?? 8;  const realItems   = products.length > 0 ? products : FALLBACK_PRODUCTS;  const displayProducts: DisplayItem[] = showPlaceholders    ? [        ...realItems.slice(0, maxSlots),        ...Array.from({ length: Math.max(0, maxSlots - realItems.length) }, (_, i) => ({          id: `ph-${i}`, name: "Product name", description: null,          price: 0, comparePrice: null, type: "DIGITAL", images: [], _ph: true,        } as DisplayItem)),      ]    : realItems.slice(0, maxSlots);  const storeName  = settings.name ?? user.name ?? "My Store";  const initials   = storeName.split(" ").map((w: string) => w[0]).join("").toUpperCase().slice(0, 2);  const types      = Array.from(new Set(realItems.map(p => p.type)));  const socialLinks = settings.socialLinks as Record<string, string>;  const activeSocials = Object.entries(socialLinks).filter(([, v]) => v);  

// bg effect — always set backgroundImage/backgroundSize to avoid React's shorthand conflict warning  const bgExtra: React.CSSProperties =    settings.backgroundEffect === "dots"      ? { backgroundImage: `radial-gradient(${theme.border} 1px, transparent 1px)`, backgroundSize: "24px 24px" }      : settings.backgroundEffect === "lines"      ? { backgroundImage: `linear-gradient(${theme.border} 1px, transparent 1px), linear-gradient(90deg, ${theme.border} 1px, transparent 1px)`, backgroundSize: "32px 32px" }      : settings.backgroundEffect === "gradient"      ? { backgroundImage: `radial-gradient(ellipse 90% 60% at 50% -10%, ${accent}22 0%, transparent 65%)`, backgroundSize: "auto" }      : { backgroundImage: "none", backgroundSize: "auto" };  const renderHeroPreview = () => {    const tagline = settings.tagline || user.bio;    const hasBanner = !!settings.bannerImage;    const heroPos = livePositions.heroContent;    const isDraggingHero = dragging?.key === "heroContent";    
// Snap grid overlay shown while dragging heroContent    const snapGridOverlay = isDraggingHero && (      <div style={{ position: "absolute", inset: 0, zIndex: 15, pointerEvents: "none" }}>        {SNAP_POINTS.map((snap, i) => {          const pos = livePositions.heroContent;          const isNear = pos            ? Math.abs(pos.x - snap.x) < SNAP_THRESHOLD && Math.abs(pos.y - snap.y) < SNAP_THRESHOLD            : false;          return (            <div key={i} style={{              position: "absolute",              left: `${snap.x}%`,              top: `${snap.y}%`,              transform: "translate(-50%, -50%)",              width: isNear ? 18 : 10,              height: isNear ? 18 : 10,              borderRadius: "50%",              background: isNear ? "#2e9cfe" : "rgba(255,255,255,0.5)",              border: isNear ? "2px solid white" : "1.5px solid rgba(46,156,254,0.6)",              transition: "all 0.1s ease",              boxShadow: isNear ? "0 0 0 4px rgba(46,156,254,0.3)" : "none",            }} />          );        })}      </div>    );    
// Helper: wraps hero content in a draggable container.    
// maxWidth is capped to whichever side has less room (e.g. at x=10%, max=20%)    
// so text wraps into a column instead of clipping against the edge.    const draggableHeroContent = (content: React.ReactNode, defaultPos: { x: number; y: number }) => {      const pos = heroPos ?? defaultPos;      const maxWidth = `${Math.min(pos.x, 100 - pos.x) * 2}%`;      return (        <div          style={{            position: "absolute",            left: `${pos.x}%`,            top: `${pos.y}%`,            transform: "translate(-50%, -50%)",            maxWidth,            zIndex: 20,            cursor: isDraggingHero ? "grabbing" : "grab",            outline: isDraggingHero ? "2px solid #2e9cfe" : "2px dashed rgba(46,156,254,0.6)",            outlineOffset: 6,            borderRadius: 8,            userSelect: "none",          }}          title="Drag to reposition · Double-click to reset"          onPointerDown={e => startDrag(e, "heroContent", heroContainerRef as React.RefObject<HTMLElement>)}          onPointerMove={e => onPointerMove(e, "heroContent")}          onPointerUp={() => onPointerUp("heroContent")}          onDoubleClick={() => onElementReset?.("heroContent")}        >          <div style={{ position: "absolute", top: -22, left: "50%", transform: "translateX(-50%)", background: "#2e9cfe", color: "white", fontSize: 9, padding: "2px 7px", borderRadius: 4, whiteSpace: "nowrap", fontWeight: 700, pointerEvents: "none", opacity: isDraggingHero ? 1 : 0.7 }}>            <Move style={{ display: "inline", width: 8, height: 8, marginRight: 3 }} />            hero content · double-click to reset          </div>          {content}        </div>      );    };    if (heroStyle === "minimal") return (      <div className="border-b flex items-center justify-between px-4 py-3" style={{ borderColor: theme.border, background: theme.heroBg }}>        <div className="flex items-center gap-2">          <div className="w-6 h-6 rounded-lg flex items-center justify-center text-white text-[8px] font-bold flex-shrink-0" style={{ background: accent }}>{initials}</div>          <span className="text-xs font-bold" style={{ color: theme.text }}>{storeName}</span>        </div>        {settings.showProductCount && <span className="text-[9px] px-2 py-0.5 rounded-full border" style={{ borderColor: theme.border, color: theme.muted }}>{realItems.length} products</span>}      </div>    );    if (heroStyle === "split") return (      <div className="border-b px-4 py-6" style={{ borderColor: theme.border, background: theme.heroBg }}>        <div className="flex items-center gap-4">          <div className="w-12 h-12 rounded-xl flex items-center justify-center text-white font-bold text-sm flex-shrink-0" style={{ background: accent }}>{initials}</div>          <div>            <h1 className="font-black text-sm" style={{ color: theme.text }}>{storeName}</h1>            {tagline && <p className="text-[10px] mt-0.5" style={{ color: theme.muted }}>{tagline}</p>}          </div>        </div>      </div>    );    const heroH = HERO_H_PX[settings.heroSize ?? "large"] ?? 540;    if (heroStyle === "cover") return (      <section ref={heroContainerRef} className="relative overflow-hidden flex items-end"        style={{ height: heroH, background: `linear-gradient(135deg, ${accent}55, ${accent}22)` }}>        {hasBanner && <img src={settings.bannerImage!} alt="" className="absolute inset-0 w-full h-full object-cover" />}        <div className="absolute inset-0 bg-black/50" />        {snapGridOverlay}        {draggableHeroContent(          <div className="flex flex-col items-center text-center px-4 max-w-md">            <h1 className="font-black text-4xl mb-2 text-white drop-shadow-lg">{storeName}</h1>            {tagline && <p className="text-base text-white/80">{tagline}</p>}          </div>,          { x: 50, y: 70 }        )}      </section>    );    if (heroStyle === "product") {      const heroBg = hasBanner ? undefined : `linear-gradient(130deg, ${accent}ee 0%, ${accent}99 45%, ${theme.bg} 100%)`;      return (        <section ref={heroContainerRef} className="relative overflow-hidden" style={{ height: heroH, background: heroBg }}>          {hasBanner && (            <>              <img src={settings.bannerImage!} alt="" className="absolute inset-0 w-full h-full object-cover" />              <div className="absolute inset-0 bg-black" style={{ opacity: (settings.heroOverlay ?? 50) / 100 }} />            </>          )}          {snapGridOverlay}          {draggableHeroContent(            <div className="flex flex-col justify-center max-w-xl">              <h1 className="font-black text-white leading-none mb-4" style={{ fontSize: "clamp(2.5rem, 6vw, 5rem)" }}>{tagline || storeName}</h1>              {tagline && <p className="text-white/70 text-base mb-6 max-w-md leading-relaxed">{storeName}</p>}              <div className="flex items-center gap-3 flex-wrap">                <div className={`inline-flex items-center text-white text-sm font-bold px-8 py-3.5 ${btnStyle.radius}`}                  style={{ background: "rgba(255,255,255,0.25)", border: "1.5px solid rgba(255,255,255,0.5)" }}>{ctaLabel}</div>              </div>            </div>,            { x: 20, y: 50 }          )}        </section>      );    }    
// storefront / centered    const heroBg = hasBanner ? undefined : `linear-gradient(160deg, ${accent}cc 0%, ${accent}88 100%)`;    return (      <section ref={heroContainerRef} className="relative overflow-hidden" style={{ height: heroH, background: heroBg }}>        {hasBanner && (          <>            <img src={settings.bannerImage!} alt="" className="absolute inset-0 w-full h-full object-cover" />            <div className="absolute inset-0 bg-black" style={{ opacity: heroOverlay / 100 }} />          </>        )}        {snapGridOverlay}        {draggableHeroContent(          <div className="flex flex-col items-center text-center max-w-2xl">            <h1 className="font-bold text-white leading-tight mb-5" style={{ fontSize: "clamp(1.75rem, 5vw, 3.25rem)" }}>{tagline || storeName}</h1>            <span className="inline-flex items-center border border-white text-white text-sm font-medium px-8 py-3">{ctaLabel}</span>          </div>,          { x: 50, y: 75 }        )}      </section>    );  };  const effectiveTrustBadges = (settings.trustBadges ?? []).length > 0    ? (settings.trustBadges ?? [])    : ["Secure Checkout", "Instant Delivery", "30-Day Returns"];  return (    <div style={{ backgroundColor: theme.bg, color: theme.text, ...bgExtra }}>      {/* Ticker / announcement */}      {(settings.tickerEnabled && settings.tickerText) ? (        <div className="overflow-hidden py-2" style={{ background: settings.announcementColor }}>          <div className="whitespace-nowrap text-white text-xs font-semibold" style={{            display: "inline-block",            animation: `ticker-scroll ${settings.tickerSpeed === "slow" ? "30s" : settings.tickerSpeed === "fast" ? "10s" : "18s"} linear infinite`,          }}>            {settings.tickerText} &nbsp;&nbsp;·&nbsp;&nbsp; {settings.tickerText}          </div>          <style>{`@keyframes ticker-scroll { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }`}</style>        </div>      ) : settings.announcementText ? (        <div className="px-4 py-2 text-center text-sm font-medium text-white" style={{ background: settings.announcementColor }}>          {settings.announcementText}        </div>      ) : null}      {/* Nav — Shopify Dawn: logo/name left · Shop+links center · search+cart right */}      <header className={`${(settings.stickyHeader ?? true) ? "sticky top-0" : ""} z-40 border-b`} style={{ background: navBg, borderColor: navBorderColor }}>        <div ref={navContainerRef} className="max-w-7xl mx-auto px-4 sm:px-8 h-14 flex items-center relative">          {/* Logo — draggable in preview */}          {(() => {            const logoPos = livePositions.navLogo;            const isActive = dragging?.key === "navLogo";            const logoContent = settings.logoImage              ? <img src={settings.logoImage} alt={storeName} className="h-7 w-auto object-contain" style={{ background: "transparent", maxWidth: 120 }} />              : <span className="text-base font-semibold tracking-tight" style={{ color: navTextColor }}>{storeName}</span>;            const wrapperStyle: React.CSSProperties = logoPos              ? { position: "absolute", left: `${logoPos.x}%`, top: "50%", transform: "translate(-50%, -50%)" }              : { flexShrink: 0 };            return (              <div                style={{ ...wrapperStyle, cursor: isActive ? "grabbing" : "grab", outline: isActive ? "2px solid #2e9cfe" : "2px dashed transparent", outlineOffset: 3, borderRadius: 6, padding: "2px 4px", userSelect: "none" }}                className="flex items-center gap-2 transition-[outline]"                title="Drag to reposition logo"                onPointerDown={e => startDrag(e, "navLogo", navContainerRef)}                onPointerMove={e => onPointerMove(e, "navLogo")}                onPointerUp={() => onPointerUp("navLogo")}                onDoubleClick={() => onElementReset?.("navLogo")}              >                {logoContent}              </div>            );          })()}          {/* Center: nav links */}          <nav className="absolute left-1/2 -translate-x-1/2 flex items-center gap-8">            <span className="text-sm" style={{ color: navTextColor }}>Shop</span>            {customButtons.slice(0, 2).map(btn => (              <span key={btn.id} className="text-sm" style={{ color: navTextColor }}>{btn.label}</span>            ))}            <span className="text-sm" style={{ color: navMutedColor }}>Portfolio</span>          </nav>          {/* Right: search + cart */}          <div className="ml-auto flex items-center">            <div className="w-10 h-10 flex items-center justify-center" style={{ color: navTextColor }}>              <Search className="w-[1.125rem] h-[1.125rem]" />            </div>            <div className="w-10 h-10 flex items-center justify-center" style={{ color: navTextColor }}>              <ShoppingCart className="w-[1.125rem] h-[1.125rem]" />            </div>          </div>        </div>      </header>      {renderHeroPreview()}      {/* Trust bar */}      {heroStyle !== "minimal" && (settings.showTrustBar ?? true) && (        <div className="border-b" style={{ borderColor: theme.border, background: theme.surface }}>          <div className="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-center gap-6 sm:gap-10 flex-wrap">            {effectiveTrustBadges.map((label: string) => (              <span key={label} className="flex items-center gap-1.5 text-xs font-semibold" style={{ color: theme.muted }}>                <Shield className="w-3 h-3" style={{ color: accent }} />                {label}              </span>            ))}          </div>        </div>      )}      <div id="products" className="max-w-7xl mx-auto px-4 sm:px-6 py-10">        {/* Section header — matches actual store */}        <div className="flex items-center justify-between gap-3 mb-6">          <div className="flex items-baseline gap-3">            <h2 className="text-xl font-medium" style={{ color: theme.text }}>{settings.sectionTitle ?? "Featured products"}</h2>            {settings.showProductCount && <span className="text-sm font-medium" style={{ color: theme.muted }}>{realItems.length} item{realItems.length !== 1 ? "s" : ""}</span>}          </div>          <div className="flex items-center gap-3">            {settings.showFilters && (              <span className="flex items-center gap-1.5 px-3 py-1.5 rounded-xl border text-xs font-medium"                style={{ background: theme.surface, borderColor: theme.border, color: theme.muted }}>                <Layers className="w-3 h-3" /> Recommended              </span>            )}            <span className="flex-shrink-0 text-sm font-semibold" style={{ color: accent }}>View all →</span>          </div>        </div>        <div className="mt-0">        <div className={isList ? "flex flex-col divide-y" : `grid gap-3 ${layout.cols}`}          style={isList ? { borderColor: theme.border } : undefined}        >          {displayProducts.map((p) => {            const M = TYPE_META[p.type];            const img = p.images?.[0];            const discount = !p._ph && p.comparePrice && p.comparePrice > p.price              ? Math.round((1 - p.price / p.comparePrice) * 100) : null;            
// ── Placeholder ghost card ──────────────────────────────────────            if (p._ph) {              if (isList) return (                <div key={p.id} className="flex items-center gap-2 py-2 opacity-40" style={{ borderBottom: `1px solid ${theme.border}` }}>                  <div className="w-8 h-8 rounded-lg flex-shrink-0" style={{ background: theme.surfaceHover }} />                  <div className="flex-1 space-y-1.5">                    <div className="h-1.5 w-2/3 rounded-full" style={{ background: theme.border }} />                    <div className="h-1.5 w-1/3 rounded-full" style={{ background: theme.border }} />                  </div>                </div>              );              if (settings.layout === "featured" && p.id === displayProducts.find(x => x._ph)?.id) return null;              return (                <div key={p.id} className={`overflow-hidden ${settings.layout === "carousel" ? "flex-shrink-0 w-24" : ""}`}                  style={{ border: `1px dashed ${theme.border}`, borderRadius: cardStyle.radius.includes("2xl") ? "12px" : cardStyle.radius.includes("xl") ? "8px" : "4px", opacity: 0.45 }}>                  <div className="aspect-square flex items-center justify-center" style={{ background: theme.surfaceHover }}>                    <Package className="w-3 h-3" style={{ color: theme.muted, opacity: 0.4 }} />                  </div>                  <div className="p-1.5 space-y-1">                    <div className="h-1.5 w-3/4 rounded-full" style={{ background: theme.border }} />                    <div className="h-1.5 w-1/2 rounded-full" style={{ background: theme.border }} />                  </div>                </div>              );            }            if (isList) return (              <div key={p.id} className="flex items-center gap-4 py-4 border-b" style={{ borderColor: theme.border }}>                <div className="w-16 h-16 flex-shrink-0 overflow-hidden" style={{ background: theme.surfaceHover }}>                  {img ? <img src={img} alt="" className="w-full h-full object-contain p-1" /> : M ? <div className="w-full h-full flex items-center justify-center" style={{ color: theme.muted }}><M.icon className="w-7 h-7 opacity-30" /></div> : null}                </div>                <div className="flex-1 min-w-0">                  <p className="text-sm leading-snug line-clamp-1" style={{ color: theme.text }}>{p.name}</p>                  <span className="text-sm mt-1 block" style={{ color: theme.text }}>{formatCurrency(p.price)}</span>                </div>                <div className="flex-shrink-0 h-9 px-4 text-sm font-medium border" style={{ borderColor: theme.border, color: theme.text, display: "flex", alignItems: "center" }}>                  Add                </div>              </div>            );            if (settings.layout === "featured" && p.id === displayProducts.find(x => !x._ph)?.id) return (              <div key={p.id} className={`col-span-full flex flex-col md:flex-row overflow-hidden ${cardStyle.radius} ${cardStyle.shadow} border`}                style={{ background: theme.surface, borderColor: theme.border }}>                <div className="md:w-1/2 aspect-video md:aspect-auto overflow-hidden" style={{ minHeight: 280, background: theme.surfaceHover }}>                  {img ? <img src={img} alt="" className="w-full h-full object-cover" /> : M ? <div className="w-full h-full flex flex-col items-center justify-center gap-3" style={{ color: theme.muted }}><M.icon className="w-16 h-16 opacity-30" /></div> : null}                </div>                <div className="flex-1 flex flex-col p-8">                  <span className="inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-wider px-2.5 py-1 rounded-full w-fit mb-4" style={{ background: `${accent}15`, color: accent }}>                    {M && <M.icon className="w-3 h-3" />} {M?.label}                  </span>                  <h3 className="font-black text-2xl mb-3 leading-tight">{p.name}</h3>                  <div className="flex items-center justify-between gap-4 mt-auto">                    <span className="font-black text-3xl" style={{ color: accent }}>{formatCurrency(p.price)}</span>                    <button className={`flex items-center gap-2 px-5 py-3 text-white font-semibold text-sm ${btnStyle.radius}`} style={{ background: accent }}>Add to Cart</button>                  </div>                </div>              </div>            );            return (              <div key={p.id} className={`cursor-pointer group ${settings.layout === "carousel" ? "flex-shrink-0 w-52" : ""}`}>                <div className={`relative overflow-hidden ${imgRatio.cls} ${cardStyle.radius} ${cardStyle.shadow}`} style={{ background: theme.surfaceHover }}>                  {img                    ? <img src={img} alt="" className="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" />                    : <div className="w-full h-full flex items-center justify-center" style={{ color: theme.muted }}>                        {M && <M.icon className="w-10 h-10 opacity-20" />}                      </div>                  }                  {discount && (settings.showSaleBadge ?? true) && (                    <div className="absolute top-2 left-2">                      <span className="text-[10px] font-semibold px-2 py-0.5 bg-red-500 text-white uppercase tracking-wide">Sale</span>                    </div>                  )}                  {!discount && (settings.showNewBadge ?? false) && !p._ph && p.id === displayProducts.find(x => !x._ph)?.id && (                    <div className="absolute top-2 right-2">                      <span className="text-[10px] font-semibold px-2 py-0.5 text-white uppercase tracking-wide" style={{ background: accent }}>New</span>                    </div>                  )}                  {/* Quick add slides up on hover */}                  {(settings.showQuickAdd ?? true) && (                    <div className="absolute bottom-0 left-0 right-0 translate-y-full group-hover:translate-y-0 transition-transform duration-200 ease-out">                      <div className="w-full py-2.5 text-xs font-semibold text-center border-t"                        style={{ background: theme.bg, borderColor: theme.border, color: theme.text }}>                        Quick add                      </div>                    </div>                  )}                </div>                <div className="pt-2">                  {(settings.showProductType ?? true) && M && (                    <p className="text-[9px] font-semibold uppercase tracking-wide mb-0.5" style={{ color: theme.muted }}>{M.label}</p>                  )}                  <p className="text-xs leading-snug line-clamp-2" style={{ color: theme.text }}>{p.name}</p>                  {(settings.showRatings ?? true) && (                    <div className="flex items-center gap-0.5 mt-1">                      {[1,2,3,4,5].map(s => <Star key={s} className={`w-2.5 h-2.5 ${s <= 4 ? "fill-amber-400 text-amber-400" : "text-gray-300"}`} />)}                    </div>                  )}                  <div className="flex items-center gap-1.5 mt-0.5">                    <span className="text-xs font-semibold" style={{ color: theme.text }}>{formatCurrency(p.price)}</span>                    {p.comparePrice && p.comparePrice > p.price && (                      <span className="text-xs line-through" style={{ color: theme.muted }}>{formatCurrency(p.comparePrice)}</span>                    )}                  </div>                </div>              </div>            );          })}        </div>        </div>      </div>      {showNewsletter && (        <div className="border-t mt-12" style={{ borderColor: theme.border }}>          <div className="max-w-7xl mx-auto px-4 sm:px-6 py-16 flex flex-col items-center text-center">            <h2 className="font-black text-2xl mb-2" style={{ color: theme.text }}>Stay in the loop</h2>            <p className="text-sm mb-6 max-w-md" style={{ color: theme.muted }}>Get notified about new products, exclusive drops, and special offers.</p>            <div className="flex gap-2 w-full max-w-md">              <div className="flex-1 h-12 px-4 rounded-xl border flex items-center text-sm" style={{ borderColor: theme.border, background: theme.surface, color: theme.muted }}>                Enter your email              </div>              <button className={`h-12 px-6 text-white text-sm font-semibold ${btnStyle.radius}`} style={{ background: accent }}>                Subscribe              </button>            </div>          </div>        </div>      )}      {settings.footerStyle !== "none" && activeSocials.length > 0 && (        <div className="border-t mt-4 py-3" style={{ borderColor: theme.border }}>          <div className="flex items-center justify-center gap-2">            {activeSocials.slice(0, 5).map(([platform]) => (              <div key={platform}                className="w-6 h-6 rounded-lg flex items-center justify-center border text-[8px] font-bold"                style={{ borderColor: theme.border, color: theme.muted, background: theme.surface }}>                {platform.slice(0, 2).toUpperCase()}              </div>            ))}          </div>        </div>      )}    </div>  );}